{
  "name": "@obusk/pnpm-plugin-defaults",
  "version": "0.5.6-3",
  "description": "oBusk defaults for pnpm",
  "files": [
    "pnpmfile.cjs"
  ],
  "main": "index.js",
  "scripts": {
    "test": "shx rm -rf test/node_modules && pnpm -C=test --no-lockfile install",
    "prepublishOnly": "esbuild --bundle src/pnpmfile.cjs --outfile=pnpmfile.cjs --platform=node"
  },
  "keywords": [
    "pnpm-config"
  ],
  "license": "MIT",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24",
      "onFail": "download"
    },
    "packageManager": {
      "name": "pnpm",
      "version": "11",
      "onFail": "download"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oBusk/pnpm-plugin-defaults.git"
  },
  "homepage": "https://github.com/oBusk/pnpm-plugin-defaults#readme",
  "bugs": {
    "url": "https://github.com/oBusk/pnpm-plugin-defaults/issues"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "shx": "^0.4.0"
  }
}
